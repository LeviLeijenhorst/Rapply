en richten op wat echt telt. Het helpen van mensen.",["$","br",null,{}],"Want dat is waarom je dit vak hebt gekozen."]}]]}],["$","div",null,{"className":"mt-6","children":["$","$L7",null,{"href":"/contact","target":"$undefined","rel":"$undefined","className":"inline-flex h-12 items-center justify-center gap-2 rounded-full px-6 py-3 text-base font-semibold transition-colors duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] border-2 border-[#BD0265] bg-[#BD0265] text-white hover:border-[#A00256] hover:bg-[#A00256] font-normal","children":[["$","span",null,{"children":"Contact"}],["$","$L6",null,{"src":"$0:f:0:1:0:props:children:1:props:children:props:children:1:props:notFound:0:props:children:1:props:children:props:children:3:props:children:1:props:src","alt":"","width":20,"height":20}]]}]}]]}]}]}]}]}]
