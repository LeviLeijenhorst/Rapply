d:["$","section",null,{"className":"w-full bg-[#F8F9F9]","children":["$","$L13",null,{"threshold":0.14,"rootMargin":"0px 0px -8% 0px","hiddenClassName":"translate-y-2 opacity-0","visibleClassName":"translate-y-0 opacity-100","className":"motion-reduce:translate-y-0 motion-reduce:opacity-100","children":["$","div",null,{"className":"mx-auto w-full max-w-6xl p-6 md:p-10 pb-0 pt-[80px] md:pb-0 md:pt-[80px]","children":["$","div",null,{"className":"flex w-full flex-col gap-[40px]","children":[["$","h2",null,{"className":"text-center font-[var(--font-catamaran)] text-[40px] font-medium leading-[120%] text-black","children":["Ontmoet ",["$","span",null,{"className":"text-[#BD0265]","children":"de oprichters"}]]}],["$","div",null,{"className":"flex w-full flex-col gap-[40px]","children":[["$","article","Levi Leijenhorst",{"className":"grid w-full overflow-hidden rounded-[24px] bg-[#F2F3F5] lg:grid-cols-2","children":[["$","div",null,{"className":"order-2 flex h-full flex-col items-start justify-center px-8 py-[80px] md:px-10 lg:order-1 lg:px-[80px]","children":[["$","h3",null,{"className":"text-[24px] font-semibold leading-[120%] text-[#BD0265]","children":"Levi Leijenhorst"}],["$","div",null,{"className":"mt-4 space-y-4","children":[["$","p","Levi heeft een achtergrond in toegepaste psychologie en merkte tijdens zijn werk als begeleider hoe tijdrovend en mentaal belastend verslaglegging kan zijn.",{"className":"text-base font-normal leading-relaxed text-[#1D0A00]","children":"Levi heeft een achtergrond in toegepaste psychologie en merkte tijdens zijn werk als begeleider hoe tijdrovend en mentaal belastend verslaglegging kan zijn."}],["$","p","Dat inzicht vormde de basis voor Rapply.",{"className":"text-base font-normal leading-relaxed text-[#1D0A00]","children":"Dat inzicht vormde de basis voor Rapply."}],["$","p","Binnen Rapply richt Levi zich op het vertalen van praktijkproblemen naar een goed doordachte digitale oplossing. De technische infrastructuur en beveiliging zijn ingericht op basis van technologie van gespecialiseerde cloud- en AI-partners die binnen de EU veel worden gebruikt voor het verwerken van gevoelige informatie.",{"className":"text-base font-normal leading-relaxed text-[#1D0A00]","children":"Binnen Rapply richt Levi zich op het vertalen van praktijkproblemen naar een goed doordachte digitale oplossing. De technische infrastructuur en beveiliging zijn ingericht op basis van technologie van gespecialiseerde cloud- en AI-partners die binnen de EU veel worden gebruikt voor het verwerken van gevoelige informatie."}],["$","p","Levi is verantwoordelijk voor de architectuurkeuzes, de manier waarop deze technologieen worden geintegreerd en de verdere doorontwikkeling van het platform. Daarnaast is hij nauw betrokken bij design, gebruikerservaring en de gesprekken met professionals die Rapply dagelijks gebruiken.",{"className":"text-base font-normal leading-relaxed text-[#1D0A00]","children":"Levi is verantwoordelijk voor de architectuurkeuzes, de manier waarop deze technologieen worden geintegreerd en de verdere doorontwikkeling van het platform. Daarnaast is hij nauw betrokken bij design, gebruikerservaring en de gesprekken met professionals die Rapply dagelijks gebruiken."}]]}],["$","$L7",null,{"href":"https://www.linkedin.com/in/levi-leijenhorst-07b1b71a2/","target":"_blank","rel":"noopener noreferrer","className":"inline-flex h-12 items-center justify-center gap-2 rounded-full px-6 py-3 text-base font-semibold transition-colors duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] border-2 border-[#BD0265] bg-[#BD0265] text-white hover:border-[#A00256] hover:bg-[#A00256] mt-10 font-normal","children":["$L15","$L16"]}]]}],"$L17"]}],"$L18"]}]]}]}]}]}]
