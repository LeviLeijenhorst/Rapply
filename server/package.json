{
  "name": "coachscribe-server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "init-db": "tsx scripts/initDb.ts"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.1.0",
    "music-metadata": "^11.7.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^24.2.0",
    "@types/pg": "^8.15.5",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  }
}
