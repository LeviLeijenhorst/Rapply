BASE_DOMAIN=yourdomain.com
CADDY_EMAIL=you@yourdomain.com

# CoachScribe server config
SUPABASE_URL=https://supabase.yourdomain.com
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
REVENUECAT_SECRET_KEY=
MISTRAL_API_KEY=
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_SUMMARY_MODEL=mistral-small-latest
MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest

# Security
CORS_ALLOWED_ORIGINS=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
ADMIN_FEEDBACK_EMAILS=contact@jnlsolutions.nl

# Protect Supabase Studio (admin) with HTTP Basic Auth.
# Generate ADMIN_BASIC_AUTH_HASH on the VM with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-strong-password'
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_HASH=REPLACE_ME

